<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
</head>

<body style="margin:0;padding:0;background:#eef2ff;font-family:Arial, sans-serif;">
  
  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center">

        <!-- Container -->
        <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;margin:40px 0;border-radius:16px;overflow:hidden">

          <!-- Header -->
          <tr>
            <td style="background:#4f46e5;padding:30px;text-align:center;color:white">
              <h2 style="margin:0;font-size:24px"><%= appName %></h2>
              <p style="margin:8px 0 0;font-size:13px;opacity:0.8">
                Email System Check
              </p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:30px">

              <h3 style="margin-top:0;color:#111827">Hello 👋</h3>

              <p style="color:#374151;font-size:15px;line-height:1.6">
                This message confirms your email notification system is working properly.
              </p>

              <!-- Highlight Box -->
              <div style="background:#eef2ff;border-left:4px solid #4f46e5;padding:16px;border-radius:8px;margin:20px 0">
                <strong style="color:#3730a3">✔ Status:</strong>
                <span style="color:#1e3a8a">Successfully connected</span>
              </div>

              <!-- Info -->
              <p style="color:#374151;font-size:14px">
                You can now receive:
              </p>

              <ul style="color:#4b5563;font-size:14px;padding-left:20px">
                <li>Login alerts</li>
                <li>Verification codes (OTP)</li>
                <li>Important system updates</li>
              </ul>

              <!-- CTA Button -->
              <div style="text-align:center;margin:30px 0">
                <a href="#"
                   style="background:#4f46e5;color:white;padding:12px 24px;
                          text-decoration:none;border-radius:8px;font-size:14px;
                          display:inline-block">
                  Go to Dashboard
                </a>
              </div>

              <!-- Warning -->
              <div style="background:#fff7ed;padding:14px;border-radius:8px;border:1px solid #fed7aa">
                <strong style="color:#c2410c">⚠ Security Notice:</strong>
                <p style="margin:6px 0 0;color:#9a3412;font-size:13px">
                  Never share your password or verification codes via email.
                </p>
              </div>

              <hr style="margin:25px 0;border:none;border-top:1px solid #e5e7eb">

              <p style="font-size:13px;color:#6b7280">
                This is an automated email. No action is required.
              </p>

              <p style="font-size:13px;color:#6b7280">
                Need help?
                <a href="mailto:<%= supportEmail %>" style="color:#4f46e5;text-decoration:none">
                  Contact Support
                </a>
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f9fafb;padding:20px;text-align:center;font-size:12px;color:#9ca3af">
              <p style="margin:0">
                Email sent to <strong><%= toEmail %></strong>
              </p>
              <p style="margin:6px 0 0">
                © <%= new Date().getFullYear() %> <%= appName %>
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>